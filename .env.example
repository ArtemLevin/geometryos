# Copy to .env only for local Compose overrides. Never commit secrets.
GEOMETRYOS_PORT=8000
GEOMETRYOS_IMAGE_TAG=local
GEOMETRYOS_BUILD_REVISION=local
GEOMETRYOS_BUILD_VERSION=0.1.0

GEOMETRYOS_GENERATE_TIMEOUT_SECONDS=15
GEOMETRYOS_VALIDATE_TIMEOUT_SECONDS=5
GEOMETRYOS_RENDER_TIMEOUT_SECONDS=10
GEOMETRYOS_MAX_INPUT_CHARS=20000
GEOMETRYOS_LOG_LEVEL=INFO
